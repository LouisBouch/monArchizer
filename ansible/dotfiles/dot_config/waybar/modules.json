{
  "sway/workspaces": {
    "disable-scoll": true,
    "all-outputs": true
  },

  "clock": {
    "format": "{:%A, %Y-%m-%d\n%H:%M}",
    "justify": "center"
  },

  "network": {
    "format-wifi": " {signalStrength}%",
    "format-ethernet": "󰈀 Connected",
    "format-disconnected": " Offline"
  },

  "cpu": {
    "format": " {usage}%"
  },

  "memory": {
    "format": "  {used}GiB|{percentage}%",
    "justify": "center"
  },

  "tray": {
    "spacing": 10
  }
}
