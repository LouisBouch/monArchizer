include /etc/sway/config

input type:keyboard {
  repeat_delay 330
  repeat_rate 40

  xkb_numlock enabled
  xkb_options "compose:ralt,caps:swapescape"
}

input type:pointer {
  accel_profile flat
  pointer_accel 0
}

output * max_render_time off
output * allow_tearing yes

output * bg ~/.config/sway/wallpapers/bg.webp fill

bar {
  status_command waybar
}

# FIgure out what rule to put in the brackets to match games and allow tearing.
# for_window [shell="xwayland"] allow_tearing yes

output DP-2 mode 1920x1080@143.981Hz

seat seat0 xcursor_theme Adwaita 24

# Keybind to lock sway and put pc to sleep.
bindsym $mod+Shift+s exec swaylock -f -i ~/.config/sway/wallpapers/bg.webp -k --indicator-radius 70 --indicator-thickness 30; systemctl suspend
